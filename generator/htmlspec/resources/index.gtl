{{define "index"}}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Index</title>
    {{template "style" .}}
</head>
<body>
    <header class="site-header">
        <div class="header-inner">
            <span class="header-logo" aria-hidden="true">◈</span>
            <h1>Test Results</h1>
        </div>
    </header>
    <div class="index-page">
        {{template "contents" .}}
    </div>
    {{template "javascript" .}}
</body>
</html>
{{end}}