{{define "base"}}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.Title}}</title>
    {{template "style" .}}
</head>
<body>
    <header class="site-header">
        <div class="header-inner">
            <span class="header-logo" aria-hidden="true">◈</span>
            <h1>{{.Title}}</h1>
        </div>
    </header>
    <div class="page-layout">
        <nav class="sidebar" aria-label="Test contents">
            {{template "contents" .}}
        </nav>
        <main class="main-content">
            {{template "test-body" .}}
        </main>
    </div>
    {{template "javascript" .}}
</body>
</html>
{{end}}