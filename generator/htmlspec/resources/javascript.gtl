{{define "javascript"}}
<script>
(function () {
    'use strict';

    function highlight(element, pairs) {
        if (!element || element.dataset.highlighted) return;
        if (!pairs.length) return;

        var classes  = pairs.map(function (p) { return p.cssClass; });
        var patterns = pairs.map(function (p) { return '(' + p.pattern + ')'; });
        var regex    = new RegExp(patterns.join('|'), 'g');

        element.innerHTML = element.innerHTML.replace(regex, function (match) {
            // arguments: match, group1, group2, ..., offset, string
            for (var i = 1; i <= classes.length; i++) {
                if (arguments[i]) {
                    return '<span class="' + classes[i - 1] + '">' + arguments[i] + '</span>';
                }
            }
            return match;
        });
        element.dataset.highlighted = 'true';
    }

    function escapeRegex(str) {
        return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }

    document.addEventListener('DOMContentLoaded', function () {

        // Highlight specification blocks
        document.querySelectorAll('.highlight.specification').forEach(function (el) {
            highlight(el, [
                {pattern: '"[^"]*"',         cssClass: 'quote'},
                {pattern: '\\bGiven\\b',     cssClass: 'keyword'},
                {pattern: '\\bAnd\\b',       cssClass: 'keyword'},
                {pattern: '\\bWhen\\b',      cssClass: 'keyword'},
                {pattern: '\\bThen\\b',      cssClass: 'keyword'},
                {pattern: '\\bNoting that\\b', cssClass: 'keyword'},
                {pattern: '[A-Z_]{2,}',      cssClass: 'constant'},
                {pattern: '\\d+',            cssClass: 'literal'}
            ]);
        });

        // Highlight results blocks
        document.querySelectorAll('.highlight.results').forEach(function (el) {
            highlight(el, [
                {pattern: '"[^"]*"',      cssClass: 'quote'},
                {pattern: '\\bFAILED\\b', cssClass: 'keyword'},
                {pattern: '\\bPASSED\\b', cssClass: 'keyword'},
                {pattern: '\\bSKIPPED\\b',cssClass: 'keyword'},
                {pattern: 'Expected',     cssClass: 'keyword'},
                {pattern: '\\bgot\\b',    cssClass: 'keyword'},
                {pattern: '[A-Z_]{2,}',   cssClass: 'constant'},
                {pattern: '\\d+',         cssClass: 'literal'}
            ]);
        });

        // Per-scenario: cross-highlight interesting givens + wire collapsibles
        document.querySelectorAll('.scenario').forEach(function (scenario) {

            // Collect interesting given values for cross-highlighting
            var interestingPairs = [];
            scenario.querySelectorAll('.interestingGiven').forEach(function (cell) {
                var text = cell.textContent.trim();
                if (text) {
                    interestingPairs.push(
                        {pattern: '"' + escapeRegex(text) + '"', cssClass: 'interestingGiven'},
                        {pattern: '\\b' + escapeRegex(text) + '\\b', cssClass: 'interestingGiven'}
                    );
                }
            });

            // Highlight XML log values
            scenario.querySelectorAll('.logValue.highlight.xml').forEach(function (logEl) {
                var first = logEl.children[0];
                if (!first || first.tagName.toLowerCase() !== 'svg') {
                    highlight(logEl, interestingPairs.concat([
                        {pattern: '"[^"]*"',        cssClass: 'quote'},
                        {pattern: '&lt;[^\\s&]+',   cssClass: 'keyword'},
                        {pattern: '\\??&gt;',        cssClass: 'keyword'},
                        {pattern: '\\s[\\w:-]+=',   cssClass: 'constant'}
                    ]));
                }
            });

            // Wire collapsible triggers
            scenario.querySelectorAll('.collapsible-trigger').forEach(function (trigger) {
                var content = trigger.nextElementSibling;
                if (content && content.classList.contains('collapsible-content')) {
                    content.classList.add('hide');
                    trigger.addEventListener('click', function () {
                        content.classList.toggle('hide');
                        trigger.classList.toggle('open');
                    });
                }
            });
        });
    });
}());
</script>
{{end}}