{{define "captured-io"}}
{{range $key, $value := .}}
<div class="scenario-section">
    <button class="collapsible-trigger" type="button" logkey="{{$key}}">
        <span class="chevron">▶</span> {{$key}}
    </button>
    <div class="collapsible-content">
        <div class="logValue highlight xml WebResource">{{$value}}</div>
    </div>
</div>
{{end}}
{{end}}